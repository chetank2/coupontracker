<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="4dp"
    android:foreground="?android:attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <!-- Coupon Image -->
        <androidx.cardview.widget.CardView
            android:layout_width="80dp"
            android:layout_height="80dp"
            app:cardCornerRadius="4dp"
            app:cardElevation="2dp">

            <ImageView
                android:id="@+id/coupon_image_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:contentDescription="Coupon crop"
                tools:src="@drawable/ic_image_placeholder" />

        </androidx.cardview.widget.CardView>

        <!-- Coupon Details -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:orientation="vertical">

            <!-- Header Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/coupon_number_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Coupon 1"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface"
                    tools:text="Coupon 1" />

                <CheckBox
                    android:id="@+id/selection_checkbox"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

            <!-- Status -->
            <TextView
                android:id="@+id/status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Complete"
                android:textSize="12sp"
                android:textColor="@color/success"
                android:background="@drawable/bg_status_complete"
                android:padding="4dp"
                android:layout_marginTop="4dp"
                tools:text="Complete" />

            <!-- Fields Count -->
            <TextView
                android:id="@+id/fields_count_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5 fields detected"
                android:textSize="12sp"
                android:textColor="@color/on_surface_variant"
                android:layout_marginTop="2dp"
                tools:text="5 fields detected" />

            <!-- Confidence -->
            <TextView
                android:id="@+id/confidence_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Confidence: 85.2%"
                android:textSize="12sp"
                android:textColor="@color/on_surface_variant"
                android:layout_marginTop="2dp"
                tools:text="Confidence: 85.2%" />

            <!-- Detected Fields -->
            <TextView
                android:id="@+id/detected_fields_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Code, Benefit, Expiry, App"
                android:textSize="11sp"
                android:textColor="@color/on_surface_variant"
                android:layout_marginTop="4dp"
                android:maxLines="2"
                android:ellipsize="end"
                tools:text="Code, Benefit, Expiry, App, Terms" />

        </LinearLayout>

        <!-- Process Button -->
        <Button
            android:id="@+id/process_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Process"
            android:textSize="12sp"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:minWidth="0dp"
            android:padding="8dp" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
