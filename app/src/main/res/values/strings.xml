    <string name="data_safety_bullet_backup_desc">Exports use Android Keystore and AES-256-GCM. Only you can decrypt them.</string>
    <string name="data_safety_bullet_tracking_title">No tracking</string>
    <string name="data_safety_bullet_tracking_desc">We don’t collect analytics from coupons. Optional usage events stay on device until you export them.</string>
